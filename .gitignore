# Claude Code harness state — local-only, never commit.
.claude/

# OS clutter
.DS_Store
Thumbs.db

# Node — not used in the build, but harmless to ignore
node_modules/
package-lock.json

# Editor cruft
*.swp
*.swo
.vscode/

# Local-only experiments and one-off calibration scripts (filenames starting with .)
# (.claude/ already covered above; this catches future ad-hoc test scripts)
.sim_*.js
.test_*.js
.build_*.js

# Temporary files from debugging — never commit
*.tmp.json
*.tmp.html
*.tmp.js

# v2.5 — keep dev artifacts out of the public docs/ folder.
# docs/ is for GitHub Pages public consumption only; NOTES + BUILD_REPORTs
# + .claude harness state stay at the repo root for the dev workflow.
docs/.claude/
docs/NOTES_v*.md
docs/BUILD_REPORT_v*.md
